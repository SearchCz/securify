<!-- SEURIFY OBSERVER -->
<!-- ===================================================== -->
<Device type="relay" id="securifyObserver" name="Securify Observer">

    <Name>Securify Observer</Name>

    <metadata>
        <product>Securify</product>
        <author>Daniel Czewski</author>
        <version>1.0.0</version>
        <license ref="Securify Community License v1.0" />
    </metadata>

    <ConfigUI>


        <Field id="schemaVersion"
                hidden="true"
            type="textfield"
            defaultValue="1.0">
            <Label>Schema Version</Label>
        </Field>


        <Field id="roomifyCooperationEnabled"
            type="checkbox"
            hidden="true"
            defaultValue="False">
        </Field>

        <Field id="enabled"
            type="checkbox"
            defaultvalue="false">
            <Label>Observer Enabled?</Label>
        </Field>

        <Field id="sep1a" type="separator">
        </Field>


        <Field id="label1a" type="label" alignText="left">
            <Label>FOCUS</Label>
        </Field>

        <Field id="label1b" type="label" alignText="left">
            <Label>* Determines which cumulative security condition activates this observer.</Label>
        </Field>

        <Field id="focusTarget"
            type="menu"
            defaultValue="-">
            <Label>This observer pays attention to:</Label>
                <List class="self" filter="stuff" method="focusTargetList"/>
        </Field>

        <Field id="focusActivator"
            type="menu"
            defaultValue="">
            <Label>... and activates when Exposure Index Classification shows:</Label>
            <List>
                <Option value="">----------------</Option>
                <Option value="allclear">[00] All Clear</Option>
                <Option value="normal">[01-19]Normal</Option>
                <Option value="noteworthy">[20-39] Noteworthy</Option>
                <Option value="significant">[40-59] Significant</Option>
                <Option value="serious">[60-79] Serious</Option>
                <Option value="critical">[80-100] Critical</Option>
                <Option value="">----------------</Option>
                <Option value="classificationchanges">Exposure Classification Change:</Option>
                <Option value="classchange">Any Classification Change</Option>
                <Option value="classincrease">Classification Increased</Option>
                <Option value="classdecrease">Clkassification Decreased</Option>
                <Option value="scorechanges">Alert Score Change:</Option>
                <Option value="scorechange">Any Score Change</Option>
                <Option value="scoreincrease">Score Increase</Option>
                <Option value="scoredecrease">Score Decrease</Option>
            </List>
        </Field>


        <Field id="sep12" type="separator">
        </Field>

        <Field id="label12" type="label" alignText="left">
            <Label>RESPONSE CONDITION</Label>
        </Field>

        <Field id="label12a" type="label" alignText="left">
            <Label>* Limits responses to activated observer until all prerequites are satisfied.</Label>
        </Field>

        <Field id="responseGated"
            type="checkbox"
            defaultValue="false">
            <Label>Only Respond when Gate Conditions Are Met</Label>
        </Field>
 
        <Field id="responsePersistenceThreshold"
            type="menu"
            defaultValue="0"
            visibleBindingId="responseGated"
            visibleBindingValue="true">
            <Label>*** Minimum Exposure Duration:</Label>
            <List>
                <Option value="0">Immediately</Option>
                <Option value="1">1 Minute</Option>
                <Option value="5">5 Minutes</Option>
                <Option value="10">10 Minutes</Option>
                <Option value="15">15 Minutes</Option>
                <Option value="30">30 Minutes</Option>
                <Option value="60">1 Hour</Option>
                <Option value="120">2 Hours</Option>
                <Option value="180">3 Hours</Option>
                <Option value="240">4 Hours</Option>
            </List>
        </Field>

        <Field id="responseGateDevice"
            type="menu"
            defaultValue="none"
            visibleBindingId="responseGated"
            visibleBindingValue="true">
            <Label>*** Response Authorization Gate:</Label>
            <List class="self" filter="stuff" method="deviceList"/>
        </Field>

        <Field id="sep2" type="separator">
        </Field>

        <Field id="label2" type="label" alignText="left">
            <Label>RESPONSE POLICIES</Label>
        </Field>

        <Field id="label2a" type="label" alignText="left">
            <Label>* Defines the policies for observer response.</Label>
        </Field>


        <Field id="log"
                type="checkbox"
                defaultValue="False"
                hidden="false"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Logfile:</Label>
        </Field>

        <Field id="announce"
                type="checkbox"
                defaultValue="False"
                hidden="false"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Announcement:</Label>
        </Field>


        <Field id="email"
                type="checkbox"
                defaultValue="False"
                hidden="false"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>eMail:</Label>
        </Field>

        <Field id="emailDevice"
            type="menu"
            visibleBindingId="email"
            visibleBindingValue="true">
            <Label alignWithCOntrol="true">eMail+ Device</Label>
            <List class="self" filter="stuff" method="getEmailDeviceList"/>
        </Field>

        <Field id="emailTo"
            type="textfield"
            visibleBindingId="email"
            visibleBindingValue="true">
            <Label alignWithCOntrol="true">To:</Label>
        </Field>

        <Field id="emailCC"
            type="textfield"
            visibleBindingId="email"
            visibleBindingValue="true">
            <Label alignWithControl="true">CC:</Label>
        </Field>

        <Field id="emailBCC"
            type="textfield"
            visibleBindingId="email"
            visibleBindingValue="true">
            <Label alignWithControl="true">BCC:</Label>
        </Field>

        <Field id="pushover"
                type="checkbox"
                defaultValue="False"
                visibleBindingId="enabled"
                visibleBindingValue="true">
               <Label>Pushover:</Label>
        </Field>

        <Field id="pushoverPriority"
            type="menu"
            visibleBindingId="pushover"
            visibleBindingValue="true"
            defaultValue="0">
            <Label alignWithCOntrol="true">Pushover Priority</Label>
            <List>
                <Option value="-1">Low (silent)</Option>
                <Option value="0">Normal</Option>
                <Option value="1">High</Option>
            </List>
        </Field>

        <Field id="pushoverSound"
            type="menu"
            visibleBindingId="pushover"
            visibleBindingValue="true"
            defaultValue="">
            <Label alignWithControl="true">Pushover Sound</Label>
            <List>
                <Option value="">Default</Option>
                <Option value="pushover">Pushover</Option>
                <Option value="bike">Bike</Option>
                <Option value="bugle">Bugle</Option>
                <Option value="cashregister">Cash Register</Option>
                <Option value="classical">Classical</Option>
                <Option value="cosmic">Cosmic</Option>
                <Option value="falling">Falling</Option>
                <Option value="gamelan">Gamelan</Option>
                <Option value="incoming">Incoming</Option>
                <Option value="intermission">Intermission</Option>
                <Option value="magic">Magic</Option>
                <Option value="mechanical">Mechanical</Option>
                <Option value="pianobar">Piano Bar</Option>
                <Option value="siren">Siren</Option>
                <Option value="spacealarm">Space Alarm</Option>
                <Option value="tugboat">Tug Boat</Option>
                <Option value="alien">Alien Alarm</Option>
                <Option value="climb">Climb</Option>
                <Option value="persistent">Persistent</Option>
                <Option value="echo">Pushover Echo</Option>
                <Option value="updown">Up Down</Option>
                <Option value="vibrate">Vibrate Only</Option>
                <Option value="none">None / Silent</Option>
            </List>
        </Field>

        <Field id="pushoverDevice"
            type="textfield"
            visibleBindingId="pushover"
            visibleBindingValue="true">
            <Label alignWithCOntrol="true">Pushover Device(s)</Label> 
        </Field>      


        <Field id="storage"
                type="checkbox"
                defaultValue="False"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Update Indigo variable:</Label>
        </Field>

        <Field id="storageSource"
            type="menu"
            defaultValue="none"
            visibleBindingId="storage"
            visibleBindingValue="true">
            <Label alignWithCOntrol="true">Target Message Length</Label>
            <List>
                <Option value="compact">Compact Description</Option>
                <Option value="medium">Medium Description</Option>
                <Option value="full">Full Description</Option>
            </List>

        </Field>

        <Field id="storageDestination"
            type="menu"
            defaultValue="none"
            visibleBindingId="storage"
            visibleBindingValue="true">
            <Label alignWithCOntrol="true">Destination Variable</Label>
            <List class="self" filter="stuff" method="getVariableList"/>
        </Field>


        <Field id="action"
                type="checkbox"
                defaultValue="False"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Execute Indigo Action Group:</Label>
        </Field>

        <Field id="actionGroup"
            type="menu"
            defaultValue="none"
            visibleBindingId="action"
            visibleBindingValue="true">
            <Label alignWithControl="true">Action Group</Label>
            <List class="self" filter="stuff" method="getActionGroupList"/>
        </Field>

        <Field id="informify"
                hidden="true"
                type="checkbox"
                defaultValue="False"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Informify (future use):</Label>
        </Field>

        <Field id="informifyRecipients"
            hidden="true"
            type="list"
            rows="6"
            defaultValue=""
            visibleBindingId="informify"
            visibleBindingValue="true">
            <Label alignWithControl="true">Recipients:</Label>
            <List class="self" filter="stuff" method="getInformifyList"/>
        </Field>


        <Field id="sep9" type="separator">
        </Field>

        <Field id="label3a" type="label" alignText="left"
                visibleBindingId="enabled"
                visibleBindingValue="true">
            <Label>PERSISTENCE</Label>
        </Field>

        <Field id="label3b" type="label" alignText="left"
                visibleBindingId="enabled"
                visibleBindingValue="true">
            <Label>* Determines how reminders of this condition are to be handled</Label>
        </Field>


        <Field id="repeat"
                type="checkbox"
                defaultValue="False"
                hidden="false"
                visibleBindingId="enabled"
                visibleBindingValue="true">
                <Label>Repeat notifications while this observation persists:</Label>
        </Field>

        <Field id="repeatMax"
            type="menu"
            defaultValue="2"
            visibleBindingId="repeat"
            visibleBindingValue="true">
            <Label>Maximum number of reminders to issue for this observation:</Label>
            <List>
                <Option value="1">1</Option>
                <Option value="2">2</Option>
                <Option value="3">3</Option>
                <Option value="4">4</Option>
                <Option value="5">5</Option>
                <Option value="10">10</Option>
                <Option value="100">100</Option>
            </List>
        </Field>

        <Field id="repeatDelay1"
            type="menu"
            defaultValue="15"
            visibleBindingId="repeat"
            visibleBindingValue="true">
            <Label>Issue first reminder after:</Label>
            <List>
                <Option value="1">1 Minute</Option>
                <Option value="5">5 Minutes</Option>
                <Option value="10">10 Minutes</Option>
                <Option value="15">15 Minutes</Option>
                <Option value="30">30 Minutes</Option>
                <Option value="60">1 Hour</Option>
                <Option value="120">2 Hours</Option>
                <Option value="180">3 Hours</Option>
                <Option value="240">4 Hours</Option>
            </List>
        </Field>

        <Field id="repeatDelayN"
            type="menu"
            defaultValue="15"
            visibleBindingId="repeat"
            visibleBindingValue="true">
            <Label>Issue additional reminders every:</Label>
            <List>
                <Option value="1">Every 1 Minutes</Option>
                <Option value="5">Every 5 Minutes</Option>
                <Option value="10">Every 10 Minutes</Option>
                <Option value="15">Every 15 Minutes</Option>
                <Option value="30">Every 30 Minutes</Option>
                <Option value="60">Every Hour</Option>
                <Option value="120">Every 2 Hours</Option>
                <Option value="180">Every 3 Hours</Option>
                <Option value="240">Every 4 Hours</Option>
            </List>
        </Field>




        <Field id="labelQ1" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ2" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ3" type="label" alignText="center">
            <Label> </Label>
        </Field>

