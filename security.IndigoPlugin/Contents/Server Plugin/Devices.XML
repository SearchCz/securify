        </Field>



    </ConfigUI>

    <States>
        <State id="houseMode">
            <ValueType>String</ValueType>
            <TriggerLabel>House Mode</TriggerLabel>
            <ControlPageLabel>House Mode</ControlPageLabel>
        </State>

        <State id="watchfulness">
