<!-- ===================================================== -->
<!-- SECURIFY CHECKPOINT -->
<!-- ===================================================== -->


    <Device type="dimmer" id="securifyCheckpoint" name="Securify Checkpoint">

        <Name>Securify Checkpoint</Name>

        <metadata>
            <product>Securify</product>
            <author>Daniel Czewski</author>
            <version>1.0.0</version>
            <license ref="Securify Community License v1.0" />
        </metadata>

        <ConfigUI>

            <!-- ===================================================== -->
            <!-- CHECKPOINT BEHAVIOR -->
            <!-- ===================================================== -->

            <Field id="schemaVersion"
                type="textfield"
                hidden="true"
                defaultValue="1.0">
                <Label>Schema Version</Label>
            </Field>

            <Field id="roomifyCooperationEnabled"
                type="checkbox"
                defaultValue="False"
                hidden="True">
                <Label>Roomify Cooperation Enabled</Label>
            </Field>

            <Field id="label1" type="label" alignText="center">
                <Label>Securify Checkpoint Definition</Label>
            </Field>

            <Field id="checkpointZone" type="menu">
                <Label>Zone/Locus</Label>
                <Description>Select the locus of this checkpoint.</Description>
                <List>
                    <Option value="FAR">Far Perimeter</Option>
                    <Option value="NEAR">Near Perimeter</Option>
                    <Option value="PREMISE">Premise</Option>
                </List>
            </Field>

           <Field id="importance"
                type="menu"
                defaultValue="50">
                <Label>Base Importance</Label>
                <List>
                    <Option value="0">None/Standby</Option>
                    <Option value="10">Low-</Option>
                    <Option value="25">Low</Option>
                    <Option value="50">Medium</Option>
                    <Option value="75">High</Option>
                    <Option value="90">High+</Option>
                    <Option value="120">Maximum</Option>
                </List>
               
            </Field>

           <Field id="escalationRate"
                type="menu"
                defaultValue="0">
                <Label>Temporal Effect:</Label>
                <List>
                    <Option value="-10">-10 points per minute</Option>
                    <Option value="-9">-9 points per minute</Option>
                    <Option value="-8">-8 points per minute</Option>
                    <Option value="-7">-7 points per minute</Option>
                    <Option value="-6">-6 points per minute</Option>
                    <Option value="-5">-5 points per minute</Option>
                    <Option value="-4">-4 points per minute</Option>
                    <Option value="-3">-3 points per minute</Option>
                    <Option value="-2">-2 points per minute</Option>
                    <Option value="-1">-1 points per minute</Option>
                    <Option value="0">None</Option>
                    <Option value="1">+1 points per minute</Option>
                    <Option value="2">+2 points per minute</Option>
                    <Option value="3">+3 points per minute</Option>
                    <Option value="4">+4 points per minute</Option>
                    <Option value="5">+5 points per minute</Option>
                    <Option value="6">+6 points per minute</Option>
                    <Option value="7">+7 points per minute</Option>
                    <Option value="8">+8 points per minute</Option>
                    <Option value="9">+9 points per minute</Option>
                    <Option value="10">+10 points per minute</Option>
                </List>
            </Field>

            <Field id="roomifyRoomId"
                type="menu"
                defaultValue="none"
                visibleBindingId="roomifyCooperationEnabled"
                visibleBindingValue="true">
                <Label>Security Status → Roomify Room</Label>
                <List class="self" filter="stuff" method="roomDeviceList"/>
            </Field>

            <Field id="sepHouseModes" type="separator" >
            </Field>

            <Field id="checkpointType" type = "menu" defaultValue="SELECT">
                <Label>Checkpoint Type</Label>
                <Description>Select the device type of this checkpoint.</Description>
                <List class="self" filter="stuff" method="checkpointTypes"/>
            </Field>

            <Field id="roomifyOccupancyId"
                type="menu"
                defaultValue="none"
                visibleBindingId="checkpointType"
                visibleBindingValue="OCCUPANCY">
                <Label>Roomify Occupancy → Securify</Label>
                <List class="self" filter="stuff" method="roomDeviceList"/>
            </Field>

            <Field id="doorSensor" type="menu"
                visibleBindingId="checkpointType"
                visibleBindingValue="DOOR">
                <Label>Open/Close Sensor</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>

            <Field id="doorLock" type="menu"
                visibleBindingId="checkpointType"
                visibleBindingValue="DOOR">
                <Label>Lock</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>

            <Field id="motionSensor" type="menu"
                visibleBindingId="checkpointType"
                visibleBindingValue="MOTION,FAULT">
                <Label>Fault Sensor</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>
        <Field id="labelQ1" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ2" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ3" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ4" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ5" type="label" alignText="center">
            <Label> </Label>
        </Field>

        <Field id="labelQ6" type="label" alignText="center">
            <Label> </Label>
        </Field>



        </ConfigUI>

